# OpenFlexure MMSS Fractal Integration
# Copy this file to .env and configure your settings

# === Microscope Configuration ===
# Set to True to use real microscope, False for mock API (development)
USE_REAL_MICROSCOPE=False

# URL of OpenFlexure Microscope Server
# Default: http://localhost:5000 (standard OpenFlexure server port)
MICROSCOPE_SERVER_URL=http://localhost:5000

# Microscope ID in the server (default: 1)
MICROSCOPE_ID=1

# === Safety Configuration ===
# Set to True to enable safety mode (commands logged but not executed)
MMSS_SAFETY_MODE_ACTIVE=False

# === Mistral AI Configuration ===
# API key for Mistral AI (optional - for advanced features)
MISTRAL_API_KEY=your_mistral_api_key_here

# === Logging ===
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
